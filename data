The Master SQL Blueprint
SQL
-- 1. Users Table (Park Staff & Management)
CREATE TABLE users (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    email VARCHAR(255) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    role ENUM('admin', 'manager', 'guide', 'cashier') NOT NULL DEFAULT 'guide',
    status ENUM('active', 'inactive') NOT NULL DEFAULT 'active',
    created_at TIMESTAMP NULL DEFAULT NULL,
    updated_at TIMESTAMP NULL DEFAULT NULL,
    deleted_at TIMESTAMP NULL DEFAULT NULL -- The Soft Delete Column
);

-- 2. Zones Table (Park Areas like Zipline, Paintball)
CREATE TABLE zones (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    status ENUM('open', 'closed', 'maintenance') NOT NULL DEFAULT 'closed',
    max_capacity INT NOT NULL DEFAULT 0,
    current_visitors INT NOT NULL DEFAULT 0,
    created_at TIMESTAMP NULL DEFAULT NULL,
    updated_at TIMESTAMP NULL DEFAULT NULL,
    deleted_at TIMESTAMP NULL DEFAULT NULL -- The Soft Delete Column
);

-- 3. Equipment Table (Safety Gear & Assets)
CREATE TABLE equipment (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    sku_code VARCHAR(255) NOT NULL UNIQUE,
    name VARCHAR(255) NOT NULL,
    category ENUM('harness', 'helmet', 'paintball_marker', 'buggy', 'other') NOT NULL,
    zone_id BIGINT UNSIGNED NULL, -- Nullable: gear might be in main storage, not in a zone
    status ENUM('available', 'in_use', 'needs_inspection', 'in_repair', 'retired') NOT NULL DEFAULT 'available',
    last_inspection_date DATE NULL,
    created_at TIMESTAMP NULL DEFAULT NULL,
    updated_at TIMESTAMP NULL DEFAULT NULL,
    deleted_at TIMESTAMP NULL DEFAULT NULL, -- The Soft Delete Column
    FOREIGN KEY (zone_id) REFERENCES zones(id) ON DELETE SET NULL
);

-- 4. Equipment Assignments (Pivot Table: Who took what gear?)
CREATE TABLE equipment_assignments (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    equipment_id BIGINT UNSIGNED NOT NULL,
    user_id BIGINT UNSIGNED NOT NULL,
    assigned_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    returned_at TIMESTAMP NULL DEFAULT NULL,
    created_at TIMESTAMP NULL DEFAULT NULL,
    updated_at TIMESTAMP NULL DEFAULT NULL,
    deleted_at TIMESTAMP NULL DEFAULT NULL, -- The Soft Delete Column
    FOREIGN KEY (equipment_id) REFERENCES equipment(id) ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- 5. Incident Reports (The Safety Trail)
CREATE TABLE incident_reports (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    user_id BIGINT UNSIGNED NOT NULL, -- Which guide reported it
    zone_id BIGINT UNSIGNED NOT NULL, -- Where it happened
    equipment_id BIGINT UNSIGNED NULL, -- Nullable: an incident might not involve gear
    severity_level ENUM('minor', 'major', 'critical') NOT NULL,
    description TEXT NOT NULL,
    status ENUM('open', 'investigating', 'resolved') NOT NULL DEFAULT 'open',
    created_at TIMESTAMP NULL DEFAULT NULL,
    updated_at TIMESTAMP NULL DEFAULT NULL,
    deleted_at TIMESTAMP NULL DEFAULT NULL, -- The Soft Delete Column
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (zone_id) REFERENCES zones(id) ON DELETE CASCADE,
    FOREIGN KEY (equipment_id) REFERENCES equipment(id) ON DELETE SET NULL
);
A Quick Note for Tomorrow's Code Session:
Since you are using Laravel, you won't actually copy-paste this raw SQL into your database. Tomorrow, you will use php artisan make:migration to create these tables.

When you write those migrations in Laravel, this SQL translates perfectly. For example, to get those exact created_at, updated_at, and deleted_at columns in your Laravel migration file, you only need to write two lines:

PHP
$table->timestamps(); // Creates created_at and updated_at
$table->softDeletes(); // Creates deleted_at